@using Model
@using System.Net.Http.Json
@inject HttpClient Http

@if (teachers == null || subjects == null || classes == null)
{
    <div class="modal-backdrop">
        <div class="edit-card text-center">
            <span class="text-muted">Lade Formulardaten...</span>
        </div>
    </div>
}
else
{
    <div class="modal-backdrop" @onclick="CancelInternal">
        <div class="edit-card" @onclick:stopPropagation="true">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="mb-0">@(Lesson.Id == 0 ? "Neue Stunde" : "Stunde bearbeiten")</h6>
                <button type="button" class="btn-icon" @onclick="CancelInternal">✕</button>
            </div>

            <EditForm Model="Lesson" OnValidSubmit="InternalHandleSubmit">
                <div class="row g-2">
                    <div class="col-6">
                        <label class="form-label small">Tag</label>
                        <InputSelect @bind-Value="Lesson.WeekDay" class="form-select form-select-sm">
                            @foreach (var day in Enum.GetValues<WeekDay>())
                            {
                                <option value="@day">@day</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="col-6">
                        <label class="form-label small">Stunde</label>
                        <InputSelect @bind-Value="Lesson.Hour" class="form-select form-select-sm">
                            @foreach (var h in Enum.GetValues<LessonHour>())
                            {
                                <option value="@h">@GetHourLabel(h)</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="col-6">
                        <label class="form-label small">Lehrer</label>
                        <InputSelect @bind-Value="Lesson.Tid" class="form-select form-select-sm">
                            <option value="0">Wählen...</option>
                            @foreach (var t in teachers)
                            {
                                <option value="@t.Id">@t.Abbr</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="col-6">
                        <label class="form-label small">Fach</label>
                        <InputSelect @bind-Value="Lesson.Sid" class="form-select form-select-sm">
                            <option value="0">Wählen...</option>
                            @foreach (var s in subjects)
                            {
                                <option value="@s.Id">@s.Desc</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="col-12">
                        <label class="form-label small">Klasse</label>
                        <InputSelect @bind-Value="Lesson.Cid" class="form-select form-select-sm">
                            <option value="0">Wählen...</option>
                            @foreach (var c in classes)
                            {
                                <option value="@c.Id">@c.Abbr</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-success">Speichern</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CancelInternal">Abbrechen</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public Lesson Lesson { get; set; } = new();
    [Parameter] public EventCallback OnSaveSuccess { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback<string> OnError { get; set; }

    private List<Teacher>? teachers;
    private List<Subject>? subjects;
    private List<SchoolClass>? classes;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            // Laden der Stammdaten für die Dropdowns
            teachers = await Http.GetFromJsonAsync<List<Teacher>>("api/teacher");
            subjects = await Http.GetFromJsonAsync<List<Subject>>("api/subject");
            classes = await Http.GetFromJsonAsync<List<SchoolClass>>("api/schoolclass");
        }
        catch (Exception ex)
        {
            await OnError.InvokeAsync("Fehler beim Laden der Listen: " + ex.Message);
        }
    }

    private async Task InternalHandleSubmit()
    {
        // Validierung: Sicherstellen, dass alles ausgewählt wurde
        if (Lesson.Tid == 0 || Lesson.Sid == 0 || Lesson.Cid == 0)
        {
            await OnError.InvokeAsync("Bitte Lehrer, Fach und Klasse auswählen.");
            return;
        }

        HttpResponseMessage response;
        if (Lesson.Id == 0)
            response = await Http.PostAsJsonAsync("api/lesson", Lesson);
        else
            response = await Http.PutAsJsonAsync($"api/lesson/{Lesson.Id}", Lesson);

        if (response.IsSuccessStatusCode)
        {
            await OnSaveSuccess.InvokeAsync();
        }
        else
        {
            var errorText = await response.Content.ReadAsStringAsync();
            await OnError.InvokeAsync(string.IsNullOrWhiteSpace(errorText) ? "Fehler beim Speichern" : errorText);
        }
    }

    private async Task CancelInternal() => await OnCancel.InvokeAsync();
    
    private string GetHourLabel(LessonHour h) => h switch
    {
        LessonHour.H1_0745 => "07:45–08:35",
        LessonHour.H2_0835 => "08:35–09:25",
        LessonHour.H3_0940 => "09:40–10:30",
        LessonHour.H4_1030 => "10:30–11:20",
        LessonHour.H5_1125 => "11:25–12:15",
        LessonHour.H6_1215 => "12:15–13:05",
        LessonHour.H7_1305 => "13:05–13:55",
        LessonHour.H8_1355 => "13:55–14:45",
        LessonHour.H9_1455 => "14:55–15:45",
        LessonHour.H10_1545 => "15:45–16:35",
        _ => h.ToString()
    };
}