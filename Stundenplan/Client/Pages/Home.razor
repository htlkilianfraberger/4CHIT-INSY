@page "/"
@using Model
@inject LessonService LessonService

<div class="container mt-4">
    <h3>Stundenplan Verwaltung</h3>

    @if (lessons == null)
    {
        <p>Lade...</p>
    }
    else
    {
        <table class="table table-sm table-bordered">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tag</th>
                    <th>Stunde</th>
                    <th>Aktionen</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in lessons)
                {
                    <tr>
                        <td>@l.Id</td>
                        <td>@l.WeekDay</td>
                        <td>@l.Hour</td>
                        <td>
                            <button class="btn btn-primary btn-sm" @onclick="() => PrepareEdit(l)">Edit</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => DeleteLesson(l.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="card p-3 mt-4">
            <h5>@(currentLesson.Id == 0 ? "Neu erstellen" : "Bearbeiten")</h5>
            <EditForm Model="currentLesson" OnValidSubmit="HandleSubmit">
                <div class="row">
                    <div class="col-md-3">
                        <label>Tag</label>
                        <InputSelect @bind-Value="currentLesson.WeekDay" class="form-control">
                            @foreach (var day in Enum.GetValues<WeekDay>())
                            {
                                <option value="@day">@day</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <label>Stunde</label>
                        <InputNumber @bind-Value="currentLesson.Hour" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label>Tid</label>
                        <InputNumber @bind-Value="currentLesson.Tid" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label>Sid</label>
                        <InputNumber @bind-Value="currentLesson.Sid" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label>Cid</label>
                        <InputNumber @bind-Value="currentLesson.Cid" class="form-control" />
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-success">Speichern</button>
                    <button type="button" class="btn btn-link" @onclick="Reset">Abbrechen</button>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    private List<Lesson>? lessons;
    private Lesson currentLesson = new();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load() => lessons = await LessonService.GetLessonsAsync();

    private void PrepareEdit(Lesson lesson)
    {
        currentLesson = new Lesson 
        { 
            Id = lesson.Id, 
            Tid = lesson.Tid, 
            Sid = lesson.Sid, 
            Cid = lesson.Cid, 
            WeekDay = lesson.WeekDay, 
            Hour = lesson.Hour 
        };
    }

    private async Task HandleSubmit()
    {
        await LessonService.SaveAsync(currentLesson);
        await Load();
        Reset();
    }

    private async Task DeleteLesson(int id)
    {
        await LessonService.DeleteAsync(id);
        await Load();
    }

    private void Reset() => currentLesson = new Lesson();
}