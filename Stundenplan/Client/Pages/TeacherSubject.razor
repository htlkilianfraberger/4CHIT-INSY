        border-radius: 7px;
        padding: 8px 20px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.15s;
    }

    .sp-btn-save:hover { background: #2d2d4e; }

    .sp-btn-cancel {
