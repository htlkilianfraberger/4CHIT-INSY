</style>

@code {
    private record TsEntry(int Tid, int Sid);
    private List<TsEntry>? teacherSubjects;
    private bool showForm = false;
    private string? errorMessage = null;

    // Für neue Zuordnung
    private int newTid = (int)TeacherEnum.ALLI + 1;
    private int newSid = (int)SubjectEnum.AM + 1;

    // Für Delete-Bestätigung
    private (int Tid, int Sid)? deletePair = null;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        teacherSubjects = await Http.GetFromJsonAsync<List<TsEntry>>("api/teachersubject");
    }

    private void ShowAddForm()
    {
        newTid = (int)TeacherEnum.ALLI + 1;
        newSid = (int)SubjectEnum.AM + 1;
        showForm = true;
    }

    private async Task HandleAdd()
    {
        var response = await Http.PostAsJsonAsync("api/teachersubject", new TsEntry(newTid, newSid));

        if (response.IsSuccessStatusCode)
        {
            await Load();
            Reset();
        }
        else
        {
            var errorText = await response.Content.ReadAsStringAsync();
            errorMessage = string.IsNullOrWhiteSpace(errorText)
                ? "Fehler beim Speichern."
                : errorText.Trim('"');
        }
    }

    private void AskDelete(int tid, int sid) => deletePair = (tid, sid);
    private void CancelDelete() => deletePair = null;

    private async Task ConfirmDelete()
    {
        if (deletePair == null) return;

        var response = await Http.DeleteAsync(
            $"api/teachersubject?tid={deletePair.Value.Tid}&sid={deletePair.Value.Sid}");

        if (response.IsSuccessStatusCode)
        {
            await Load();
        }
        else
        {
            var errorText = await response.Content.ReadAsStringAsync();
            errorMessage = string.IsNullOrWhiteSpace(errorText) ? "Fehler beim Löschen." : errorText.Trim('"');
        }

        deletePair = null;
    }

    private void Reset() { showForm = false; }

    private static readonly Dictionary<SubjectEnum, int> SubjectColors = new()
    {
        { SubjectEnum.AM,   0  }, { SubjectEnum.D,    1  }, { SubjectEnum.E1,   2  },
        { SubjectEnum.INSY, 3  }, { SubjectEnum.RK,   4  }, { SubjectEnum.SEW,  5  },
        { SubjectEnum.SYTD, 6  }, { SubjectEnum.GGPH, 7  }, { SubjectEnum.GGPG, 8  },
        { SubjectEnum.NW2P, 9  }, { SubjectEnum.NW2C, 10 }, { SubjectEnum.DSAI, 11 },
        { SubjectEnum.WIR,  12 }, { SubjectEnum.ITPL, 13 }, { SubjectEnum.ITPP, 14 },
        { SubjectEnum.BESP, 15 }, { SubjectEnum.SYTI, 16 }, { SubjectEnum.SYTS, 17 },
    };

    private string GetSubjectAbbr(int sid)
    {
        var val = sid - 1;
        return Enum.IsDefined(typeof(SubjectEnum), val) ? ((SubjectEnum)val).ToString() : sid.ToString();
    }

    private string GetTeacherAbbr(int tid)
    {
        var val = tid - 1;
        return Enum.IsDefined(typeof(TeacherEnum), val) ? ((TeacherEnum)val).ToString() : tid.ToString();
    }

    private int GetSubjectColor(int sid)
    {
        var val = sid - 1;
        if (Enum.IsDefined(typeof(SubjectEnum), val))
            return SubjectColors.TryGetValue((SubjectEnum)val, out var c) ? c : 0;
        return 0;
    }
}