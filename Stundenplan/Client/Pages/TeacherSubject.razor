@page "/teachersubjects"
@using Model
@using System.Net.Http.Json
@using System.Text.Json
@inject HttpClient Http

<div class="sp-page">
    <div class="sp-header">
        <div>
            <h1 class="sp-title">Lehrer-Fach Zuordnungen</h1>
            <span class="sp-subtitle">Welcher Lehrer unterrichtet welches Fach</span>
        </div>
        <button class="sp-btn-add" @onclick="ShowAddForm">+ Neue Zuordnung</button>
    </div>

    @if (teacherSubjects == null)
    {
        <div class="sp-loading"><span>Lade Zuordnungen…</span></div>
    }
    else
    {
        @* ── Tabelle ── *@
        <div class="ts-table-wrapper">
            <table class="ts-table">
                <thead>
                    <tr>
                        <th>Lehrer</th>
                        <th>Fach</th>
                        <th class="th-actions"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var ts in teacherSubjects)
                {
                    <tr>
                        <td>
                            <span class="badge badge-teacher">@GetTeacherAbbr(ts.Tid)</span>
                        </td>
                        <td>
                            <span class="badge badge-subject lc-@GetSubjectColor(ts.Sid)">
                                @GetSubjectAbbr(ts.Sid)
                            </span>
                        </td>
                        <td class="td-actions">
                            <button class="la-btn la-del" title="Löschen"
                                    @onclick="() => AskDelete(ts.Tid, ts.Sid)">✕</button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        @* ── Toast ── *@
        @if (errorMessage != null)
        {
            <div class="sp-toast sp-toast-error" @onclick="() => errorMessage = null">
                <span class="toast-icon">⚠</span> @errorMessage
                <span class="toast-dismiss">✕</span>
            </div>
        }

        @* ── Add Modal ── *@
        @if (showForm)
        {
            <div class="modal-backdrop" @onclick="Reset">
                <div class="modal-card" @onclick:stopPropagation="true">
                    <div class="modal-card-header">
                        <span>Neue Zuordnung hinzufügen</span>
                        <button class="modal-close" @onclick="Reset">✕</button>
                    </div>
                    <div class="modal-fields">
                        <div class="field-group">
                            <label>Lehrer</label>
                            <select class="sp-select" @bind="newTid">
                                @foreach (var t in Enum.GetValues<TeacherEnum>())
                                {
                                    <option value="@((int)t + 1)">@t</option>
                                }
                            </select>
                        </div>
                        <div class="field-group">
                            <label>Fach</label>
                            <select class="sp-select" @bind="newSid">
                                @foreach (var s in Enum.GetValues<SubjectEnum>())
                                {
                                    <option value="@((int)s + 1)">@s</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="modal-actions">
                        <button class="sp-btn-save" @onclick="HandleAdd">Speichern</button>
                        <button class="sp-btn-cancel" @onclick="Reset">Abbrechen</button>
                    </div>
                </div>
            </div>
        }

        @* ── Delete Confirm Modal ── *@
        @if (deletePair != null)
        {
            <div class="modal-backdrop" @onclick="CancelDelete">
                <div class="modal-card modal-card-sm" @onclick:stopPropagation="true">
                    <div class="delete-icon">⚠</div>
                    <div class="modal-card-header modal-card-header-center">
                        <span>Zuordnung löschen?</span>
                    </div>
                    <div class="delete-body">
                        <div class="delete-preview">
                            <span class="badge badge-teacher">@GetTeacherAbbr(deletePair.Value.Tid)</span>
                            <span class="delete-arrow">→</span>
                            <span class="badge badge-subject lc-@GetSubjectColor(deletePair.Value.Sid)">
                                @GetSubjectAbbr(deletePair.Value.Sid)
                            </span>
                        </div>
                        <p class="delete-hint">Diese Zuordnung wird unwiderruflich entfernt.</p>
                        <div class="delete-actions">
                            <button class="sp-btn-danger" @onclick="ConfirmDelete">Ja, löschen</button>
                            <button class="sp-btn-cancel" @onclick="CancelDelete">Abbrechen</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

<style>
